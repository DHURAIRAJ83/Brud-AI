# Tamil AI Assistant - Environment Variables
# Copy this file to .env and fill in values

# Ollama settings (Use http://host.docker.internal:11434 if running backend inside Docker to connect to host Ollama)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT=60

# Ollama cloud base URL (VPS)
CLOUD_OLLAMA_URL=
RUNTIME_MODE=hybrid
CLOUD_CONSENT=false

# Embedding model (CPU-friendly)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# RAG settings
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5

# Memory settings
MEMORY_MAX_TURNS=10

# Upload settings
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20

# Cache settings
CACHE_MAX_SIZE=256
CACHE_TTL_SECONDS=300

# Security
SECRET_KEY=tamil-ai-phase5-secret-change-in-production
SECURITY_ENABLED=true
ADMIN_INITIAL_PASSWORD=
ADMIN_API_KEY=rudran_86e41d65f9c64383ba471056
CORS_ALLOWED_ORIGINS=

# App settings
APP_ENV=development
LOG_LEVEL=INFO

# Database Settings
AGENT_DB_PATH=
MEMORY_DB_PATH=
